{
  "name": "bgc-server",
  "version": "1.0.0",
  "description": "Bombay Gaming Company - API Server",
  "main": "index.js",
  "scripts": {
    "start": "node --experimental-sqlite index.js",
    "dev": "nodemon --exec \"node --experimental-sqlite\" index.js",
